# flock-zorch runtime dependencies.
#
# Pulled from the Fractalyze package index alongside upstream PyPI:
#   pip install -r requirements.in \
#     --extra-index-url https://fractalyze.github.io/pypi/simple/
#
# flock-zorch is the flock-specific consumer of zorch's agnostic blocks; zorch
# itself arrives as a Bazel module (see MODULE.bazel), not a pip dep.
absl-py
numpy
# Lockstep with the zorch git_override pin in MODULE.bazel (flock-byte-fiat-shamir).
# That branch migrated onto the jax_fork jax-cuda12 stack (zorch#194), so this MUST
# mirror zorch's own requirements.in. The pre-migration zkx-cuda-pjrt / 0.0.5.dev
# wheels lack the interior-padding lowering lincheck's `_seg_xor_fold`
# (jax.lax.associative_scan) needs — the sha2/blake3 GPU gates raise
# NotImplementedError on them. Bump these together with the submodule pin.
jax==0.10.0.dev20260713024812
jaxlib==0.10.0.dev20260713024812
jax-cuda12-plugin==0.10.0.dev20260713024812
jax-cuda12-pjrt==0.10.0.dev20260713024812
# zk_dtypes ships the native field dtypes jax lowers; arrives transitively via
# jax but the resolver lags, so pin it so the lock tracks the jax wheel.
# 0.0.10 adds the flat AES-basis binary_field_gf8_aes dtype (zk_dtypes#157).
zk-dtypes==0.0.10

# Benchmark harness (shared across fractalyze repos); used only by the
# //flock_zorch/...:*bench* targets, not by the flock-zorch wheel itself.
zkbench==0.4.0
