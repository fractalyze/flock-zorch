# flock-zorch runtime dependencies.
#
# Pulled from the Fractalyze package index alongside upstream PyPI:
#   pip install -r requirements.in \
#     --extra-index-url https://fractalyze.github.io/pypi/simple/
#
# flock-zorch is the flock-specific consumer of zorch's agnostic blocks; zorch
# itself arrives as a Bazel module (see MODULE.bazel), not a pip dep.
absl-py
numpy
# Lockstep with the zorch git_override pin in MODULE.bazel. frx/frxlib are the
# Fractalyze jax_fork rebrand; this MUST mirror zorch's own requirements.in and
# stay on the same version so the GPU kernels are byte-identical. The stack
# carries the interior-padding lowering lincheck's `_seg_xor_fold`
# (frx.lax.associative_scan) needs — older wheels raise NotImplementedError on
# the sha2/blake3 GPU gates. Bump these together with the zorch git_override pin.
frx==0.10.0.dev20260722083811
frxlib==0.10.0.dev20260722083811
frx-cuda12-plugin==0.10.0.dev20260722083811
frx-cuda12-pjrt==0.10.0.dev20260722083811
# zk_dtypes ships the native field dtypes frx lowers; arrives transitively via
# frx but the resolver lags, so pin it so the lock tracks the frx wheel.
# 0.0.10 adds the flat AES-basis binary_field_gf8_aes dtype (zk_dtypes#157).
zk-dtypes==0.0.10
