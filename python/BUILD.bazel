# No golden: `CscCircuit.fold_alpha_batched` (device seg-scan) vs a naive host
# XOR-scatter reference — the non-identity A₀/B₀ structure coverage.
py_test(
    name = "csc_fold_test",
    size = "small",
    srcs = ["flock_zorch/lincheck/testing/csc_fold_test.py"],
    deps = [
        ":flock_zorch",
        ":test_support",
        requirement("absl-py"),
    ],
)

# No golden: prove_packed → verify round-trip for the zerocheck verifier (accept +
# claim reconstruction + tamper rejection). Software-mul, so it runs on CPU.
py_test(
    name = "zerocheck_verify_test",
    # medium like lincheck_verify_test: ~35s locally but a loaded CI runner has
    # hit small's 60s cap (61.3s timeout on an otherwise-green branch).
    size = "medium",
    srcs = ["flock_zorch/zerocheck/testing/zerocheck_verify_test.py"],
    deps = [
        ":flock_zorch",
        ":test_support",
        requirement("absl-py"),
    ],
)

# No golden: prove zerocheck+lincheck → verify both, claim reconstruction + tamper
