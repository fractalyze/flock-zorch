+
+// Kernel-only throughput sweep (data device-resident, H2D/D2H excluded) for the
+// #23 head-to-head vs the compiler's fused lax.ntt on binary_field_t5. Hidden by
+// default ([.]); run with:  ./ntt_tests "[bench]"
+TEST_CASE("Additive NTT kernel timing sweep", "[.][bench]") {
+	const int log_rate = 0;
+	const int iters = 50;
+	std::cout << "log_h,kernel_ms,elem_per_s\n";
+	for (int log_h = 10; log_h <= 23; log_h++) {
+		std::mt19937 gen(0xdeadbeef + log_h + log_rate);
+		size_t inp_size = 1 << log_h;
+		size_t out_size = 1 << (log_h + log_rate);
+		NTTData<uint32_t> ntt_inp(DataOrder::IN_ORDER, inp_size);
+		for (size_t i = 0; i < inp_size; i++) ntt_inp.data[i] = gen();
+
+		AdditiveNTTConf<uint32_t, FanPaarTowerField<5>> conf(log_h, log_rate);
+		AdditiveNTT<uint32_t, FanPaarTowerField<5>> ntt(conf);
+		NTTData<uint32_t> ntt_out(out_size);
+
+		ntt.apply(ntt_inp, ntt_out);  // warmup (compile/caches)
+		double acc_ms = 0.0;
+		for (int it = 0; it < iters; it++) {
+			ntt.apply(ntt_inp, ntt_out);
+			acc_ms += ntt.last_kernel_ms;
+		}
+		double ms = acc_ms / iters;
+		double eps = (double)inp_size / (ms / 1e3);
+		printf("%d,%.5f,%.4e\n", log_h, ms, eps);
+	}
+}
